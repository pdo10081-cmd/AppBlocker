<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="40dp"
    android:background="@color/bg_blocked">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🔒"
        android:textSize="80sp"
        android:layout_marginBottom="28dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Заблокировано"
        android:textSize="34sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Это приложение недоступно\nс полуночи до 8 утра"
        android:textSize="16sp"
        android:textColor="#B0B3C6"
        android:gravity="center"
        android:lineSpacingMultiplier="1.5"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🕗  Доступно после 08:00"
        android:textSize="15sp"
        android:textColor="#7C83F7"
        android:layout_marginBottom="48dp"/>

    <Button
        android:id="@+id/btn_home"
        android:layout_width="260dp"
        android:layout_height="52dp"
        android:text="На главный экран"
        android:textSize="16sp"
        android:backgroundTint="#5C6BC0"
        android:textColor="#FFFFFF"/>

</LinearLayout>
